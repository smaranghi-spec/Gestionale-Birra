<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Dettaglio ricetta</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background: #f7f3ee; }
        h1 { color: #5a381e; }
        .box { background: white; padding: 20px; border-radius: 10px; max-width: 600px; }
        a { color: #8b5a2b; }
    </style>
</head>
<body>
    <div class="box">
        <h1>{{ ricetta.nome }}</h1>
        <p><strong>ID:</strong> {{ ricetta.id }}</p>
        <p><strong>Tipo:</strong> {{ ricetta.tipo }}</p>
        <p><strong>Volume target:</strong> {{ ricetta.volume_target_litri }} L</p>
        <p><strong>Efficienza:</strong> {{ ricetta.efficienza }}</p>
        <p><strong>Versione:</strong> {{ ricetta.versione }}</p>
        <p><strong>Note:</strong> {{ ricetta.note }}</p>

        <p><a href="/ricette/html">Torna all'elenco ricette</a></p>
    </div>
</body>
</html>